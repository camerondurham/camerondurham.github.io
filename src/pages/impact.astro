---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const impact = (await getCollection('impact')).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Impact | Cameron Durham">
  <h1>Selected Industry Impact</h1>
  <p class="intro">
    These entries summarize outcomes from proprietary systems. They focus on scope, approach, and measurable results while excluding sensitive implementation details.
  </p>

  <div class="impact-list">
    {impact.map(item => (
      <article class="impact-item">
        <header>
          <h2>{item.data.title}</h2>
          {item.data.period && <p class="period">{item.data.period}</p>}
        </header>

        <p>{item.data.summary}</p>

        <p class="scope"><strong>Scope:</strong> {item.data.scope}</p>

        <h3>Outcomes</h3>
        <ul>
          {item.data.outcomes.map(outcome => <li>{outcome}</li>)}
        </ul>

        <h3>Approach</h3>
        <ul>
          {item.data.methods.map(method => <li>{method}</li>)}
        </ul>

        <p class="visibility"><strong>Visibility:</strong> {item.data.visibility}</p>

        {item.data.proof.length > 0 && (
          <p class="proof">
            <strong>Proof:</strong>{' '}
            {item.data.proof.map((link, idx) => (
              <>
                <a href={link.url} target="_blank" rel="noopener noreferrer">{link.label}</a>
                {idx < item.data.proof.length - 1 ? ', ' : ''}
              </>
            ))}
          </p>
        )}
      </article>
    ))}
  </div>
</BaseLayout>

<style>
.intro { margin-bottom: 2rem; color: var(--text-1); }
.impact-list { display: flex; flex-direction: column; gap: 2rem; }
.impact-item { border-bottom: 1px solid var(--border-color); padding-bottom: 2rem; }
.impact-item:last-child { border-bottom: none; }
.impact-item h2 { margin-bottom: 0.3rem; }
.impact-item h2::before, .impact-item h3::before { content: none; }
.period { color: var(--text-2); font-family: var(--mono-text-font); margin-bottom: 0.75rem; }
.scope, .visibility, .proof { margin-top: 0.75rem; }
.impact-item h3 { margin-top: 1rem; margin-bottom: 0.5rem; font-size: 1rem; }
</style>
